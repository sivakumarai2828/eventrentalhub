# ---- Database ----
# Local dev fallback (no external services needed):
DATABASE_URL=sqlite:///./eventrenthub.db
# Supabase Postgres (use the "Connection string" > URI, swap driver to psycopg):
# DATABASE_URL=postgresql+psycopg://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ---- Supabase ----
SUPABASE_URL=https://<your-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Project Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=item-images

# ---- CORS (comma-separated) ----
CORS_ORIGINS=http://localhost:5173

# ---- Email (optional; logs to console when disabled) ----
EMAILS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=EventRentHub <no-reply@eventrenthub.com>
