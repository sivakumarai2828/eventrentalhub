# Supabase project credentials (Project Settings > API)
VITE_SUPABASE_URL=https://<your-ref>.supabase.co
# New-style publishable key (sb_publishable_...). The legacy
# VITE_SUPABASE_ANON_KEY is also accepted as a fallback.
VITE_SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>
VITE_SUPABASE_STORAGE_BUCKET=item-images

# Base URL of the FastAPI backend.
# Leave blank in dev to use the Vite proxy (/api -> http://localhost:8000).
# In production set it to your Render URL, e.g. https://eventrenthub-api.onrender.com
VITE_API_BASE_URL=
